{
	"name": "dataflow1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "adls_output",
						"type": "DatasetReference"
					},
					"name": "sourceNew"
				},
				{
					"dataset": {
						"referenceName": "adls_output1",
						"type": "DatasetReference"
					},
					"name": "sourceDim"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "lookup1"
				},
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          CustomerID as integer,",
				"          Name as string,",
				"          City as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceNew",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceDim",
				"derivedColumn1, sourceDim lookup(CustomerID == CustomerID,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup1",
				"sourceNew derive(CustomerID = toInteger(CustomerID)) ~> derivedColumn1"
			]
		}
	}
}