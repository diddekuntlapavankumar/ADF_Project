{
	"name": "dataflow1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "adls_output",
						"type": "DatasetReference"
					},
					"name": "sourceNew"
				},
				{
					"dataset": {
						"referenceName": "dim_customer_file",
						"type": "DatasetReference"
					},
					"name": "sourceDim"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "lookup1"
				},
				{
					"name": "split1"
				},
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          CustomerID as integer,",
				"          Name as string,",
				"          City as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceNew",
				"source(output(",
				"          CustomerID as integer,",
				"          Name as string,",
				"          City as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceDim",
				"sourceNew, sourceDim lookup(sourceNew@CustomerID == sourceNew@CustomerID",
				"     && sourceNew@Name == sourceDim@Name",
				"     && sourceNew@City == sourceDim@City,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup1",
				"lookup1 split(isNull(sourceDim@CustomerID),",
				"     !isNull(sourceDim@CustomerID) && (     sourceNew@Name != sourceDim@Name ||     sourceNew@City != sourceDim@City ),",
				"     !isNull(sourceDim@CustomerID)    && sourceNew@Name ==sourceDim@Name  && sourceNew@City == sourceDim@City,",
				"     disjoint: false) ~> split1@(NewRecords, UpdatedRecords, UnchangedRecords, OtherRecords)",
				"split1@NewRecords derive(CustomerID = ERROR_FUNCTION('Start_Date = currentTimestamp() End_Date = toTimestamp(__SINGLE_QUOTE__9999-12-31__SINGLE_QUOTE__) Current_Flag = __SINGLE_QUOTE__Y__SINGLE_QUOTE__')) ~> derivedColumn1"
			]
		}
	}
}