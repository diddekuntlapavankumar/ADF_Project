								"recursive": true,
								"enablePartitionDiscovery": false
							},
							"formatSettings": {
								"type": "DelimitedTextReadSettings"
							}
						}
					},
					{
						"name": "Loop_Files",
						"type": "ForEach",
						"dependsOn": [
							{
								"activity": "Get_File_List",
