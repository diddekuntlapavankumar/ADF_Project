{
	"name": "AzureSqlDatabase1",
	"properties": {
		"parameters": {
			"server": {
				"type": "string"
			},
			"user": {
				"type": "string"
			},
			"password": {
				"type": "string"
			},
			"db": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "AzureSqlDatabase",
		"typeProperties": {
			"server": "@{linkedService().server}",
			"database": "@{linkedService().db}",
			"encrypt": "mandatory",
			"trustServerCertificate": false,
			"authenticationType": "SQL",
			"userName": "@{linkedService().user}",
			"password": {
				"type": "AzureKeyVaultSecret",
				"store": {
					"referenceName": "AKV_Sql_sqlserver",
					"type": "LinkedServiceReference"
				},
				"secretName": "db-pwd"
			}
		}
	}
}